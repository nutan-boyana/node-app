<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 col-lg-2 bg-dark text-white min-vh-100 p-3">
      <%- include('includes/sidebar', { user: user }) %>
    </div>
    <div class="col-md-3 col-lg-10 p-4">
      <button onclick="window.location.href='/create-user'" class="btn btn-primary mb-3">
        + Create User
      </button>
      <table border="1">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody id="userTable"></tbody>
      </table>
    </div>
  </div>
</div>

<script>
  fetch('/getAllUsers')
    .then(res => res.json())
    .then(data => {
      let table = document.getElementById('userTable');
      table.innerHTML = "";

      data.users.forEach(u => {
        table.innerHTML += `
        <tr id="row-${u.id}">
          <td>${u.id}</td>
          <td>${u.name}</td>
          <td>${u.email}</td>
          <td>${u.role}</td>
          <td>
            <button onclick="editUser(${u.id})" class="btn btn-primary">Edit</button>
            <button onclick="deleteUser(${u.id})" class="btn btn-danger">Delete</button>
          </td>
        </tr>
        `;
      });
    });

  
  window.deleteUser = function (id) {
    fetch('/delete-user/' + id, { method: 'DELETE' })
      .then(res => res.json())
      .then(data => {
        if (data.status === 'success') {
          document.getElementById('row-' + id).remove(); 
        } else {
          alert('Delete failed');
        }
      })
      .catch(err => {
        console.error(err);
        alert('Server error');
      });
  };

  window.editUser = function (id) {
    window.location.href = '/editUser/' + id;
  };
</script>