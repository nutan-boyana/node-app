<div class="container-fluid">
  <div class="row">

    <!-- Sidebar -->
    <div class="col-md-3 col-lg-2 bg-dark text-white min-vh-100 p-3">
      <%- include('../includes/sidebar', { user: user }) %>
    </div>

    <!-- Main Content -->
    <div class="col-md-9 col-lg-10 p-4">

      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Departments</h4>
        <button onclick="window.location.href='/create-department'" class="btn btn-primary">
          + Create Department
        </button>
      </div>

      <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover align-middle">
          <thead class="table-dark">
            <tr>
              <th scope="col">ID</th>
              <th scope="col">Department Name</th>
              <th scope="col" class="text-center">Actions</th>
            </tr>
          </thead>

          <tbody id="departmentTable"></tbody>
        </table>
      </div>

    </div>
  </div>
</div>

<script>
  fetch('/getAllDepartments')
    .then(res => res.json())
    .then(data => {
      let table = document.getElementById('departmentTable');
      table.innerHTML = "";

      data.departments.forEach(d => {
        const isDeleted = d.delete_status === 1;
        const rowClass = isDeleted ? 'table-secondary text-muted' : '';
        const toggleChecked = isDeleted ? '' : 'checked';
        const buttons = `
          <button onclick="editDepartment(${d.department_id})" class="btn btn-primary btn-sm me-2" ${isDeleted ? 'disabled' : ''}>Edit</button>
          <div class="form-check form-switch d-inline-block align-middle mb-0 me-2" title="Toggle Active Status">
            <input class="form-check-input" style="cursor: pointer;" type="checkbox" onchange="toggleDepartmentStatus(${d.department_id}, this)" ${toggleChecked}>
          </div>
          <button onclick="deleteDepartment(${d.department_id})" class="btn btn-danger btn-sm">Delete</button>
        `;

        table.innerHTML += `
        <tr id="row-${d.department_id}" class="${rowClass}">
          <td>${d.department_id}</td>
          <td class="${isDeleted ? 'text-decoration-line-through' : ''}">${d.department_name}</td>
          <td>${buttons}</td>
        </tr>
        `;
      });
    });

  window.toggleDepartmentStatus = function (id, checkbox) {
    const isDeleted = !checkbox.checked;
    const deleteStatus = isDeleted ? 1 : 0;
    const confirmMsg = isDeleted ? "Are you sure you want to soft-delete this department?" : "Are you sure you want to restore this department?";
    
    if(!confirm(confirmMsg)) {
        checkbox.checked = !checkbox.checked; // Revert UI
        return;
    }

    fetch('/toggle-department-status/' + id, { 
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ delete_status: deleteStatus })
    })
      .then(res => res.json())
      .then(data => {
        if (data.status === 'success') {
          window.location.reload(); 
        } else {
          alert('Update failed');
          checkbox.checked = !checkbox.checked;
        }
      })
      .catch(err => {
        console.error(err);
        alert('Server error');
        checkbox.checked = !checkbox.checked;
      });
  };

  window.deleteDepartment = function (id) {
    if(!confirm("Are you sure you want to PERMANENTLY delete this department?")) return;
    fetch('/delete-department/' + id, { method: 'DELETE' })
      .then(res => res.json())
      .then(data => {
        if (data.status === 'success') {
          window.location.reload(); 
        } else {
          alert('Delete failed');
        }
      })
      .catch(err => {
        console.error(err);
        alert('Server error');
      });
  };

  // Implement editDepartment if needed in the future
</script>