<html>

<head>
    <title>Login</title>
    <%- include('includes/header') %>
</head>

<body>

    <section class="loginblock">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="loginwrap">
                        <!-- <div class="imgwrap">
                            <img src="/assets/images/loginimg.webp">
                        </div> -->
                        <div class="formblock">
                            <div class="formwrap">
                                <div class="wrap">
                                    <label>Email</label>
                                    <input type="email" id="emailaddress">
                                    <span class="text-danger" id="email_error"></span>
                                </div>
                                <div class="wrap">
                                    <label>Password</label>
                                    <input type="password" id="password">
                                    <span class="text-danger" id="passwordError"></span>
                                    <i class="fas fa-eye eyeabs password-eye"></i>
                                </div>
                                <button class="submitbtn" id="button">Login</button>
                                <div class="text-danger" id="invalid"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

  
    <script>
        $(document).ready(function () {
            // Toggle password visibility
            $(".password-eye").on("click", function () {
                var password = $("#password");
                var passwordFieldType = password.attr("type");

                if (passwordFieldType === "password") {
                    password.attr("type", "text");
                } else {
                    password.attr("type", "password");
                }
            });

            // Clear error message on input
            $("#emailaddress, #password").on('input', function () {
                if (this.id === 'emailaddress') {
                    $('#email_error').text('');
                }
                if (this.id === 'password') {
                    $('#passwordError').text('');
                }
            });

            // Login submit
            $("#button").on('click', function (event) {
                event.preventDefault();
                $(".text-danger").text(""); // Clear previous error messages
                var email = $("#emailaddress").val();
                var password = $("#password").val();
                var isValid = true;
                var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (email.trim() === '') {
                    $("#email_error").text("Please enter your email");
                    isValid = false;
                }
                if (isValid && !emailRegex.test(email)) {
                    $("#email_error").text("Invalid email format");
                    isValid = false;
                }
                if (password.trim() === '') {
                    $("#passwordError").text("Please enter your password");
                    isValid = false;
                }

                if (isValid) {
                    $('#button').html(`<div class="spinner-border spinner-border-sm" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                       </div>`);
                   $.ajax({
                        type: 'POST',
                        dataType: "json",
                        data: { user_name: email, user_password: password },
                        url: '/login',
                        success: function (response) {
                            $('#button').html(`Login`);

                            if (response.status === 'Invalid credentials') {
                                $("#invalid").text("Invalid Credentials").show();
                            } else {
                                window.location.href = '/dashboard';
                            }
                        },
                        error: function () {
                            $('#button').html(`Login`);
                            $("#invalid").text("Something went wrong").show();
                        }
                    });
                }
            });
        });
    </script>

</body>

</html>
