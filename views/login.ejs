<!DOCTYPE html>
<html>

<head>
    <title>Login</title>
    <%- include('includes/header') %>
</head>

<body class="bg-light">

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow p-4 w-100" style="max-width: 400px;">

            <h4 class="text-center mb-4">Login</h4>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" id="emailaddress" class="form-control">
                <div class="text-danger small" id="email_error"></div>
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>

                <div class="position-relative">
                    <input type="password" id="password" class="form-control pe-5">

                    <i class="fas fa-eye position-absolute top-50 end-0 translate-middle-y me-3 password-eye"
                        style="cursor: pointer;"></i>
                </div>

                <div class="text-danger small" id="passwordError"></div>
            </div>

            <button class="btn btn-primary w-100" id="button">Login</button>

            <div class="text-danger text-center mt-2 small" id="invalid"></div>

        </div>
    </div>

    <script>
        $(document).ready(function () {

            $(".password-eye").on("click", function () {
                var password = $("#password");
                password.attr("type", password.attr("type") === "password" ? "text" : "password");
            });

            $("#emailaddress, #password").on('input', function () {
                if (this.id === 'emailaddress') $('#email_error').text('');
                if (this.id === 'password') $('#passwordError').text('');
            });

            $("#button").on('click', function (event) {
                event.preventDefault();
                $(".text-danger").text("");

                var email = $("#emailaddress").val();
                var password = $("#password").val();
                var isValid = true;
                var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                if (email.trim() === '') {
                    $("#email_error").text("Please enter your email");
                    isValid = false;
                } else if (!emailRegex.test(email)) {
                    $("#email_error").text("Invalid email format");
                    isValid = false;
                }

                if (password.trim() === '') {
                    $("#passwordError").text("Please enter your password");
                    isValid = false;
                }

                if (isValid) {
                    $('#button').html(`<span class="spinner-border spinner-border-sm"></span>`);

                    $.ajax({
                        type: 'POST',
                        dataType: "json",
                        data: { user_name: email, user_password: password },
                        url: '/login',
                        success: function (response) {
                            $('#button').html(`Login`);

                            if (response.status === 'Invalid credentials') {
                                $("#invalid").text("Invalid Credentials");
                            } else {
                                window.location.href = '/dashboard';
                            }
                        },
                        error: function () {
                            $('#button').html(`Login`);
                            $("#invalid").text("Something went wrong");
                        }
                    });
                }
            });

        });
    </script>

</body>

</html>